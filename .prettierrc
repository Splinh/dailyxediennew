{
	"$schema": "https://json.schemastore.org/prettierrc",
	"printWidth": 200,
	"tabWidth": 4,
	"useTabs": true,
	"semi": true,
	"singleQuote": true,
	"quoteProps": "as-needed",
	"jsxSingleQuote": false,
	"trailingComma": "all",
	"bracketSpacing": true,
	"bracketSameLine": false,
	"arrowParens": "always",
	"proseWrap": "preserve",
	"htmlWhitespaceSensitivity": "css",
	"endOfLine": "lf",
	"embeddedLanguageFormatting": "auto",
	"singleAttributePerLine": false,
	"overrides": [
		{
			"files": ["*.yaml", "*.yml"],
			"options": {
				"singleQuote": false
			}
		},
		{
			"files": ["*.md", "*.mdx"],
			"options": {
				"proseWrap": "always",
				"printWidth": 100
			}
		},
		{
			"files": ["*.html", "*.php"],
			"options": {
				"printWidth": 300,
				"htmlWhitespaceSensitivity": "ignore"
			}
		}
	]
}
