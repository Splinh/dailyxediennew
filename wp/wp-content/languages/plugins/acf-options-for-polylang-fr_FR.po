#: classes/admin.php:44
msgid "Use the language switcher in the admin bar to change the language."
msgstr "Utilisez le sélecteur de langue situé dans la barre d’administration pour changer de langue."

#. Description of the plugin
#: bea-acf-options-for-polylang.php
msgid "Improves Polylang by adding per-language support for ACF options pages—each language can have its own option values."
msgstr "Améliore Polylang en ajoutant une prise en charge par langue pour les pages d’options d’ACF : chaque langue peut désormais disposer de ses propres valeurs d’options."

#: classes/admin.php:41
msgid "<strong>Be careful</strong>, you are going to modify the untranslated options, they will probably be used as defaults if the translation is not completed."
msgstr "<strong>Soyez prudent</strong>, vous êtes sur le point de modifier des options non traduites, elles seront probablement utilisées par défaut si la traduction n’est pas terminée."

#. translators: %s: current language name
#: classes/admin.php:39
msgid "You are changing the options for language %s"
msgstr "Vous modifiez les options pour la langue %s"

#. Author of the plugin
