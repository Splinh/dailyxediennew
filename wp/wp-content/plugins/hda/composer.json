{
	"name": "plugins/hda",
	"description": "Essential WordPress toolkit for security, custom assets, and admin utilities.",
	"license": "MIT",
	"autoload": {
		"psr-4": {
			"HDAddons\\": "src/"
		}
	},
	"require": {
		"php": ">=8.1",
		"enshrined/svg-sanitize": "^0.22",
		"matthiasmullie/minify": "^1.3",
		"yahnis-elsts/plugin-update-checker": "^5.6",
		"geoip2/geoip2": "^3.3",
		"openspout/openspout": "^5.3"
	},
	"require-dev": {
		"roave/security-advisories": "dev-latest",
		"phpunit/phpunit": "^10.0",
		"yoast/phpunit-polyfills": "^2.0"
	},
	"scripts": {
		"post-autoload-dump": [
			"HDAddons\\Build\\ModuleMapGenerator::generate"
		]
	},
	"config": {
		"optimize-autoloader": true
	}
}
