<?xml version="1.0"?>
<ruleset name="HDA Plugin">
	<description>Custom PHPCS ruleset for HDA plugin</description>

	<!-- Scan only PHP files -->
	<arg name="extensions" value="php"/>

	<!-- Custom capabilities -->
	<rule ref="WordPress.WP.Capabilities">
		<properties>
			<property name="custom_capabilities" type="array">
				<element value="hda_manage_options"/>
			</property>
		</properties>
	</rule>
</ruleset>
